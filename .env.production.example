# Paste into Vercel → Production (no trailing slash on API URL).
# Secrets only in Vercel — do not commit real NEXTAUTH_SECRET / Google secret to git.

# Nest API origin only (no `/api` suffix — that points at Next.js and breaks signup CORS).
NEXT_PUBLIC_API_BASE_URL=https://ai-copilot-backend.vercel.app
API_BASE_URL=https://ai-copilot-backend.vercel.app
NEXTAUTH_URL=https://reimage-three.vercel.app

NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
