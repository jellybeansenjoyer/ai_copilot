# Copy to Vercel (or `.env.local` for local checks).
# NEXT_PUBLIC_* are inlined at build time — set them in Vercel before “Deploy”.
#
# Production deploy pair (see docs/VERCEL.md):
# Use the Nest API host only — never the Next.js URL, and do not append /api
# (otherwise signup becomes /api/auth/signup on the wrong app and CORS fails).
#   NEXT_PUBLIC_API_BASE_URL=https://ai-copilot-backend.vercel.app
#   API_BASE_URL=https://ai-copilot-backend.vercel.app
#   NEXTAUTH_URL=https://reimage-three.vercel.app
#
# Rare: set only if you use a non-default Nest hostname on Vercel and the guard blocks you.
# NEXT_PUBLIC_DISABLE_NEST_ORIGIN_GUARD=true

# Public URL of your Nest API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=

# Same as above — required for NextAuth callbacks & server-side fetches (auth, etc.)
API_BASE_URL=

# NextAuth — production: https://reimage-three.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (same OAuth client as backend verifies, if you use Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (browser upload from Profile dialog)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
